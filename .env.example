# =============================================================================
# MULTICA - Environment Configuration
# =============================================================================
# Copia este archivo a .env y rellena los valores antes de desplegar.
# NO subas el archivo .env a Git (ya está en .gitignore).
# =============================================================================

# -----------------------------------------------------------------------------
# BASE DE DATOS (Obligatorio)
# -----------------------------------------------------------------------------
POSTGRES_DB=multica
POSTGRES_USER=multica
# GENERA UNA CONTRASEÑA FUERTE (ej: openssl rand -hex 32)
POSTGRES_PASSWORD=

# -----------------------------------------------------------------------------
# BACKEND - JWT (Obligatorio)
# -----------------------------------------------------------------------------
# GENERA UN SECRETO FUERTE (ej: openssl rand -base64 64)
JWT_SECRET=

# -----------------------------------------------------------------------------
# DOMINIOS Y URLS (Obligatorio)
# -----------------------------------------------------------------------------
# IMPORTANTE: Estas URLs deben ser ACCESIBLES DESDE EL NAVEGADOR (no localhost
# ni nombres de red Docker). Usa tus dominios públicos reales.
#
# Ejemplo para local (docker-compose.local.yml):
#   FRONTEND_ORIGIN=http://localhost:3000
#   MULTICA_APP_URL=http://localhost:3000
#   MULTICA_PUBLIC_URL=http://localhost:8080
#
# Ejemplo para producción (Dokploy):
#   FRONTEND_ORIGIN=https://work.moonsbow.com
#   MULTICA_APP_URL=https://work.moonsbow.com
#   MULTICA_PUBLIC_URL=https://api.moonsbow.com

FRONTEND_ORIGIN=https://work.moonsbow.com
MULTICA_APP_URL=https://work.moonsbow.com
MULTICA_PUBLIC_URL=https://api.moonsbow.com

# Orígenes permitidos para CORS. Generalmente igual a FRONTEND_ORIGIN.
# Si tienes múltiples frontends, sepáralos con comas.
CORS_ALLOWED_ORIGINS=https://work.moonsbow.com

# Dominio para cookies de sesión.
# - Déjalo VACÍO si frontend y backend están en subdominios distintos
#   (ej: work.moonsbow.com y api.moonsbow.com)
# - Pon ".moonsbow.com" si compartes cookies entre subdominios
COOKIE_DOMAIN=

# -----------------------------------------------------------------------------
# EMAIL - Opción A: Resend (Recomendado para producción)
# -----------------------------------------------------------------------------
# Obtén tu API key en https://resend.com
# Si no configuras email, los códigos de verificación se imprimen en los logs
# del backend (útil para desarrollo local).
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@moonsbow.com

# -----------------------------------------------------------------------------
# EMAIL - Opción B: SMTP (Alternativa self-hosted)
# -----------------------------------------------------------------------------
# Solo configura si NO usas Resend. SMTP tiene prioridad sobre Resend.
SMTP_HOST=
SMTP_PORT=25
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_TLS_INSECURE=false

# -----------------------------------------------------------------------------
# GOOGLE OAUTH (Opcional)
# -----------------------------------------------------------------------------
# Para login con Google. Crea credenciales en https://console.cloud.google.com
# El redirect URI debe coincidir con tu dominio público del frontend.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://work.moonsbow.com/auth/callback

# -----------------------------------------------------------------------------
# S3 / CLOUDFRONT - Almacenamiento de archivos (Opcional)
# -----------------------------------------------------------------------------
# Si no configuras S3, los archivos se guardan localmente en el volumen.
S3_BUCKET=
S3_REGION=us-west-2
CLOUDFRONT_DOMAIN=
CLOUDFRONT_KEY_PAIR_ID=
CLOUDFRONT_PRIVATE_KEY=

# -----------------------------------------------------------------------------
# CONTROL DE REGISTRO
# -----------------------------------------------------------------------------
# Desactiva nuevos registros si solo tú vas a usar la instancia:
ALLOW_SIGNUP=true

# Opcional: restringir por dominio de email (ej: moonsbow.com)
ALLOWED_EMAIL_DOMAINS=

# Opcional: restringir a emails específicos (separados por comas)
ALLOWED_EMAILS=

# -----------------------------------------------------------------------------
# SEGURIDAD Y RED
# -----------------------------------------------------------------------------
# CIDRs de proxies confiados.
# - En Dokploy: 127.0.0.1/32 suele ser suficiente
# - Si usas Cloudflare: añade sus rangos IP oficiales
MULTICA_TRUSTED_PROXIES=127.0.0.1/32

# Entorno: production activa verificaciones de seguridad adicionales.
APP_ENV=production

# Token para métricas en tiempo real. Genera uno si quieres acceder al endpoint.
REALTIME_METRICS_TOKEN=

# TTL del token de autenticación (default: 30 días en segundos)
AUTH_TOKEN_TTL=2592000

# -----------------------------------------------------------------------------
# GITHUB INTEGRATION (Opcional)
# -----------------------------------------------------------------------------
# Para conectar repositorios de GitHub. Crea un GitHub App.
GITHUB_APP_SLUG=
GITHUB_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# REDIS / RATE LIMITING (Opcional)
# -----------------------------------------------------------------------------
# Redis mejora el rate limiting y el realtime.
# Si no lo configuras, rate limiting está desactivado (fail-open).
# En Docker usa el nombre del servicio: redis://redis:6379/0
REDIS_URL=
RATE_LIMIT_AUTH=5
RATE_LIMIT_AUTH_VERIFY=20

# -----------------------------------------------------------------------------
# AGENT WORKER (Contenedor de agentes de IA)
# -----------------------------------------------------------------------------
# URLs de conexión al servidor Multica. En producción, usá los dominios públicos.
# En local, usá los puertos del host o los nombres de servicio Docker.
MULTICA_SERVER_URL=https://space-api.moonsbow.com
MULTICA_APP_URL=https://space.moonsbow.com

# Token de autenticación (opcional). Lo obtenés al loguearte en la web.
MULTICA_AUTH_TOKEN=

# -----------------------------------------------------------------------------
# KIMI WORKER (Kimi CLI de Moonshot AI)
# -----------------------------------------------------------------------------
# API Key de Moonshot AI. Obtenela en: https://platform.moonshot.cn/
# Se usa tanto como KIMI_API_KEY como MOONSHOT_API_KEY (compatibilidad).
KIMI_API_KEY=

# API Keys para otros agentes de IA (opcionales)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# -----------------------------------------------------------------------------
# VERSIONES DE IMAGEN
# -----------------------------------------------------------------------------
# Puedes fijar a una versión específica en lugar de 'latest'
MULTICA_IMAGE_TAG=latest
