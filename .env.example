# =============================================================================
# MULTICA - Dokploy Environment Configuration
# =============================================================================
# Copia este archivo a .env y rellena los valores antes de desplegar en Dokploy.
# NO subas el archivo .env real a Git.
# =============================================================================

# -----------------------------------------------------------------------------
# BASE DE DATOS (Obligatorio)
# -----------------------------------------------------------------------------
POSTGRES_DB=multica
POSTGRES_USER=multica
# GENERA UNA CONTRASEÑA FUERTE (ej: openssl rand -base64 32)
POSTGRES_PASSWORD=cambia-esto-por-una-contraseña-muy-segura

# -----------------------------------------------------------------------------
# BACKEND - JWT (Obligatorio)
# -----------------------------------------------------------------------------
# GENERA UN SECRETO FUERTE (ej: openssl rand -base64 64)
JWT_SECRET=cambia-esto-por-un-secreto-jwt-muy-largo-y-seguro

# -----------------------------------------------------------------------------
# DOMINIOS (Obligatorio - adapta a tus dominios)
# -----------------------------------------------------------------------------
# Dominio donde estará el frontend (configurado en Dokploy UI)
# Ejemplo: https://multica.tudominio.com o https://app.tudominio.com
FRONTEND_ORIGIN=https://multica.tudominio.com

# La misma URL del frontend, usada internamente por el backend
MULTICA_APP_URL=https://multica.tudominio.com

# URL pública del backend API (para webhooks y URLs absolutas)
# Debe coincidir con el dominio que configures para el backend en Dokploy UI
MULTICA_PUBLIC_URL=https://multica-api.tudominio.com

# Orígenes permitidos para CORS. Usualmente igual a FRONTEND_ORIGIN.
# Si usas múltiples subdominios, sepáralos con comas:
# CORS_ALLOWED_ORIGINS=https://app.tudominio.com,https://multica.tudominio.com
CORS_ALLOWED_ORIGINS=https://multica.tudominio.com

# Dominio para cookies de sesión. Déjalo vacío si frontend y backend 
# están en subdominios diferentes o usas un solo dominio.
# Si usas app.ejemplo.com y api.ejemplo.com, pon: .ejemplo.com
COOKIE_DOMAIN=

# -----------------------------------------------------------------------------
# EMAIL - Opción A: Resend (Recomendado para producción)
# -----------------------------------------------------------------------------
# Obtén tu API key en https://resend.com
# Si no configuras email, los códigos de verificación se imprimen en los logs
# del backend y podrás verlos en Dokploy → Logs.
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@multica.ai

# -----------------------------------------------------------------------------
# EMAIL - Opción B: SMTP (Alternativa self-hosted)
# -----------------------------------------------------------------------------
# Solo configura si NO usas Resend. SMTP tiene prioridad sobre Resend.
SMTP_HOST=
SMTP_PORT=25
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_TLS_INSECURE=false

# -----------------------------------------------------------------------------
# GOOGLE OAUTH (Opcional)
# -----------------------------------------------------------------------------
# Para login con Google. Crea credenciales en https://console.cloud.google.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Debe coincidir con tu dominio:
GOOGLE_REDIRECT_URI=https://multica.tudominio.com/auth/callback

# -----------------------------------------------------------------------------
# S3 / CLOUDFRONT - Almacenamiento de archivos (Opcional)
# -----------------------------------------------------------------------------
# Si no configuras S3, los archivos se guardan localmente en el volumen.
S3_BUCKET=
S3_REGION=us-west-2
CLOUDFRONT_DOMAIN=
CLOUDFRONT_KEY_PAIR_ID=
CLOUDFRONT_PRIVATE_KEY=

# -----------------------------------------------------------------------------
# CONTROL DE REGISTRO (Recomendado para instancias privadas)
# -----------------------------------------------------------------------------
# Desactiva nuevos registros si solo tú vas a usar la instancia:
ALLOW_SIGNUP=true

# Opcional: restringir por dominio de email (ej: tudominio.com)
ALLOWED_EMAIL_DOMAINS=

# Opcional: restringir a emails específicos (separados por comas)
ALLOWED_EMAILS=

# -----------------------------------------------------------------------------
# SEGURIDAD Y RED
# -----------------------------------------------------------------------------
# CIDRs de proxies confiados (Dokploy/Traefik suele estar en 127.0.0.1/32).
# Si usas Cloudflare u otro CDN, añade sus rangos.
MULTICA_TRUSTED_PROXIES=127.0.0.1/32

# Entorno: production activa verificaciones de seguridad adicionales.
APP_ENV=production

# Token para métricas en tiempo real. Genera uno si quieres acceder al endpoint.
REALTIME_METRICS_TOKEN=

# TTL del token de autenticación (default: 30 días en segundos)
AUTH_TOKEN_TTL=2592000

# -----------------------------------------------------------------------------
# GITHUB INTEGRATION (Opcional)
# -----------------------------------------------------------------------------
# Para conectar repositorios de GitHub. Crea un GitHub App.
GITHUB_APP_SLUG=
GITHUB_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# REDIS / RATE LIMITING (Opcional)
# -----------------------------------------------------------------------------
# Redis mejora el rate limiting y el realtime. 
# Si no lo configuras, rate limiting está desactivado (fail-open).
REDIS_URL=
RATE_LIMIT_AUTH=5
RATE_LIMIT_AUTH_VERIFY=20

# -----------------------------------------------------------------------------
# VERSIONES DE IMAGEN
# -----------------------------------------------------------------------------
# Puedes fijar a una versión específica en lugar de 'latest'
MULTICA_IMAGE_TAG=latest
